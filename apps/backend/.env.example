# Backend environment template.
#
# The app loads ONE of two files based on NODE_ENV (see src/config/env.ts):
#   NODE_ENV=production -> .env.prod   (the VPS; Mongo/Redis on localhost)
#   otherwise           -> .env.dev    (local dev; Docker Compose services)
#
# Both files are git-ignored. Copy this template to create them:
#   cp .env.example .env.dev
#   cp .env.example .env.prod
# then adjust the values below per environment.

# Port the API listens on.
PORT=4000

# Browser origin allowed by CORS. In prod this is the deployed frontend.
#   dev:  http://localhost:5173
#   prod: https://www.geobioguessr.com
CLIENT_ORIGIN=http://localhost:5173

# MongoDB runs locally — in Docker for dev, natively on the VPS for prod.
MONGO_URL=mongodb://localhost:27017
MONGO_DB=geobiograph

# Redis runs locally — in Docker for dev, natively on the VPS for prod.
REDIS_URL=redis://localhost:6379

# Cache lifetimes (seconds).
SEARCH_CACHE_TTL=300
GAME_SESSION_TTL=86400
